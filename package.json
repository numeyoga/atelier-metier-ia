{
  "name": "atelier-metier-ia",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":               "vite dev",
    "build":             "vite build",
    "preview":           "wrangler pages dev .svelte-kit/cloudflare",
    "db:migrate:local":  "wrangler d1 migrations apply atelier-metier-ia",
    "db:migrate:remote": "wrangler d1 migrations apply atelier-metier-ia --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@sveltejs/adapter-cloudflare": "^4.0.0",
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "vite": "^8.0.0",
    "wrangler": "^3.0.0"
  }
}
